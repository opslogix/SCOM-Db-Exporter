{
  "Mappings": [
    {
      "ObjectName": "Processor Information",
      "CounterName": "% Processor Time",
      "MetricName": "windows_cpu_time_total",
      "Labels": {
        "instance": "{instance}",
        "mode": "total"
      },
      "ValueMultiplier": 1.0
    },
    {
      "ObjectName": "Processor Information",
      "CounterName": "% DPC Time",
      "MetricName": "windows_cpu_time_total",
      "Labels": {
        "instance": "{instance}",
        "mode": "dpc"
      },
      "ValueMultiplier": 1.0
    },
    {
      "ObjectName": "Processor Information",
      "CounterName": "% Interrupt Time",
      "MetricName": "windows_cpu_time_total",
      "Labels": {
        "instance": "{instance}",
        "mode": "interrupt"
      },
      "ValueMultiplier": 1.0
    },
    {
      "ObjectName": "Memory",
      "CounterName": "Available MBytes",
      "MetricName": "windows_memory_physical_free_bytes",
      "Labels": {
        "instance": "{instance}"
      },
      "ValueMultiplier": 1048576.0
    },
    {
      "ObjectName": "Memory",
      "CounterName": "PercentMemoryUsed",
      "MetricName": "windows_memory_used_percent",
      "Labels": {
        "instance": "{instance}"
      },
      "ValueMultiplier": 1.0
    },
    {
      "ObjectName": "LogicalDisk",
      "CounterName": "Free Megabytes",
      "MetricName": "windows_logical_disk_free_bytes",
      "Labels": {
        "volume": "{entity}",
        "instance": "{instance}"
      },
      "ValueMultiplier": 1048576.0
    },
    {
      "ObjectName": "LogicalDisk",
      "CounterName": "% Free Space",
      "MetricName": "windows_logical_disk_percent_free",
      "Labels": {
        "volume": "{entity}",
        "instance": "{instance}"
      },
      "ValueMultiplier": 1.0
    },
    {
      "ObjectName": "LogicalDisk",
      "CounterName": "% Idle Time",
      "MetricName": "windows_logical_disk_idle_seconds_total",
      "Labels": {
        "volume": "{entity}",
        "instance": "{instance}"
      },
      "ValueMultiplier": 1.0
    },
    {
      "ObjectName": "LogicalDisk",
      "CounterName": "Disk Read Bytes/sec",
      "MetricName": "windows_logical_disk_read_bytes_total",
      "Labels": {
        "volume": "{entity}",
        "instance": "{instance}"
      },
      "ValueMultiplier": 1.0
    },
    {
      "ObjectName": "LogicalDisk",
      "CounterName": "Disk Write Bytes/sec",
      "MetricName": "windows_logical_disk_write_bytes_total",
      "Labels": {
        "volume": "{entity}",
        "instance": "{instance}"
      },
      "ValueMultiplier": 1.0
    },
    {
      "ObjectName": "Network Adapter",
      "CounterName": "Bytes Received/sec",
      "MetricName": "windows_net_bytes_received_total",
      "Labels": {
        "nic": "{entity}",
        "instance": "{instance}"
      },
      "ValueMultiplier": 1.0
    },
    {
      "ObjectName": "Network Adapter",
      "CounterName": "Bytes Total/sec",
      "MetricName": "windows_net_bytes_total",
      "Labels": {
        "nic": "{entity}",
        "instance": "{instance}"
      },
      "ValueMultiplier": 1.0
    },
    {
      "ObjectName": "System",
      "CounterName": "System Up Time",
      "MetricName": "windows_system_system_up_time",
      "Labels": {
        "instance": "{instance}"
      },
      "ValueMultiplier": 1.0
    }
  ]
}
